  31:../APP/LCD/Src/lcd_menu.c ****  * @brief Draw soft rounded rectangle (Windows 11 style - larger radius)
  32:../APP/LCD/Src/lcd_menu.c ****  */
  33:../APP/LCD/Src/lcd_menu.c **** static void LCD_FillRoundRect(u16 x1, u16 y1, u16 x2, u16 y2, u16 color)
  34:../APP/LCD/Src/lcd_menu.c **** {
  35:../APP/LCD/Src/lcd_menu.c ****     /* Fill main rectangle */
  36:../APP/LCD/Src/lcd_menu.c ****     LCD_Fill(x1 + 3, y1, x2 - 3, y2, color);      /* Top/bottom margins */
  37:../APP/LCD/Src/lcd_menu.c ****     LCD_Fill(x1 + 2, y1 + 1, x2 - 2, y2 - 1, color);
  38:../APP/LCD/Src/lcd_menu.c ****     LCD_Fill(x1 + 1, y1 + 2, x2 - 1, y2 - 2, color);
  39:../APP/LCD/Src/lcd_menu.c ****     LCD_Fill(x1, y1 + 3, x2, y2 - 3, color);      /* Full height center */
  40:../APP/LCD/Src/lcd_menu.c **** }
  41:../APP/LCD/Src/lcd_menu.c **** 
  42:../APP/LCD/Src/lcd_menu.c **** /**
  43:../APP/LCD/Src/lcd_menu.c ****  * @brief Draw rounded border only (Windows 11 style)
  44:../APP/LCD/Src/lcd_menu.c ****  */
  45:../APP/LCD/Src/lcd_menu.c **** static void LCD_DrawRoundRectBorder(u16 x1, u16 y1, u16 x2, u16 y2, u16 color)
  46:../APP/LCD/Src/lcd_menu.c **** {
  47:../APP/LCD/Src/lcd_menu.c ****     /* Horizontal lines */
  48:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 4, y1, x2 - 4, y1, color);
  49:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 4, y2 - 1, x2 - 4, y2 - 1, color);
  50:../APP/LCD/Src/lcd_menu.c **** 
  51:../APP/LCD/Src/lcd_menu.c ****     /* Vertical lines */
  52:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1, y1 + 4, x1, y2 - 4, color);
  53:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x2 - 1, y1 + 4, x2 - 1, y2 - 4, color);
  54:../APP/LCD/Src/lcd_menu.c **** 
  55:../APP/LCD/Src/lcd_menu.c ****     /* Corner pixels for smooth radius */
  56:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 2, y1 + 1, x1 + 3, y1 + 1, color);
  57:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x2 - 4, y1 + 1, x2 - 3, y1 + 1, color);
  58:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 1, y1 + 2, x1 + 1, y1 + 3, color);
  59:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x2 - 2, y1 + 2, x2 - 2, y1 + 3, color);
  60:../APP/LCD/Src/lcd_menu.c **** 
  61:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 2, y2 - 2, x1 + 3, y2 - 2, color);
  62:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x2 - 4, y2 - 2, x2 - 3, y2 - 2, color);
  63:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x1 + 1, y2 - 4, x1 + 1, y2 - 3, color);
  64:../APP/LCD/Src/lcd_menu.c ****     LCD_DrawLine(x2 - 2, y2 - 4, x2 - 2, y2 - 3, color);
  65:../APP/LCD/Src/lcd_menu.c **** }
  66:../APP/LCD/Src/lcd_menu.c **** 
  67:../APP/LCD/Src/lcd_menu.c **** /* Helper: Ease-out cubic function */
  68:../APP/LCD/Src/lcd_menu.c **** static float ease_out_cubic(float t) {
  69:../APP/LCD/Src/lcd_menu.c ****     float f = t - 1.0f;
  70:../APP/LCD/Src/lcd_menu.c ****     return f * f * f + 1.0f;
  71:../APP/LCD/Src/lcd_menu.c **** }
