  15:../APP/LCD/Src/lcd_menu.c **** /* Windows 11 Fluent Design Color Palette */
  16:../APP/LCD/Src/lcd_menu.c **** #define WIN11_BG           0xFFFF    /* Pure white background */
  17:../APP/LCD/Src/lcd_menu.c **** #define WIN11_BG_GRAY      0xF7BE    /* #F3F3F3 Light gray */
  18:../APP/LCD/Src/lcd_menu.c **** #define WIN11_ACCENT       0x03DA    /* #0078D4 Windows blue */
  19:../APP/LCD/Src/lcd_menu.c **** #define WIN11_ACCENT_LIGHT 0x4E1C    /* #9DCBF0 Light blue */
  20:../APP/LCD/Src/lcd_menu.c **** #define WIN11_ACCENT_PALE  0xE73C    /* #E3F2FD Very light blue */
  21:../APP/LCD/Src/lcd_menu.c **** #define WIN11_TEXT_PRIMARY 0x18E7    /* #1F1F1F Near black */
  22:../APP/LCD/Src/lcd_menu.c **** #define WIN11_TEXT_SECOND  0x632C    /* #666666 Gray */
  23:../APP/LCD/Src/lcd_menu.c **** #define WIN11_BORDER       0xE71C    /* #E5E5E5 Border gray */
  24:../APP/LCD/Src/lcd_menu.c **** #define WIN11_SHADOW       0xD69A    /* #D0D0D0 Subtle shadow */
  25:../APP/LCD/Src/lcd_menu.c **** #define WIN11_HOVER_BG     0xF7DF    /* #F5F5F5 Hover state */
  26:../APP/LCD/Src/lcd_menu.c **** 
  27:../APP/LCD/Src/lcd_menu.c **** /* Menu context */
  28:../APP/LCD/Src/lcd_menu.c **** static MenuContext_t menu_ctx = {0};
  29:../APP/LCD/Src/lcd_menu.c **** 
  30:../APP/LCD/Src/lcd_menu.c **** /**
