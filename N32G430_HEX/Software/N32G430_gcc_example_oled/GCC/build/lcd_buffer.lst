 103:../APP/LCD/Src/lcd_buffer.c **** 
 104:../APP/LCD/Src/lcd_buffer.c ****     /* Send full screen using repeated buffer writes */
 105:../APP/LCD/Src/lcd_buffer.c ****     uint32_t total_pixels = LCD_W * LCD_H;
 106:../APP/LCD/Src/lcd_buffer.c ****     uint32_t pixels_per_chunk = LCD_W * BUFFER_HEIGHT;
 107:../APP/LCD/Src/lcd_buffer.c **** 
 108:../APP/LCD/Src/lcd_buffer.c ****     for (uint32_t chunk = 0; chunk < (LCD_H / BUFFER_HEIGHT); chunk++) {
 109:../APP/LCD/Src/lcd_buffer.c ****         status = HAL_SPI_Transmit_DMA(&hspi1, (uint8_t *)lcd_ctx.framebuffer, pixels_per_chunk * 2)
 110:../APP/LCD/Src/lcd_buffer.c ****         if (status != HAL_OK) {
 111:../APP/LCD/Src/lcd_buffer.c ****             LCD_CS_Set();
 112:../APP/LCD/Src/lcd_buffer.c ****             return status;
 113:../APP/LCD/Src/lcd_buffer.c ****         }
 114:../APP/LCD/Src/lcd_buffer.c ****         LCD_Buffer_WaitComplete();
 115:../APP/LCD/Src/lcd_buffer.c ****     }
 116:../APP/LCD/Src/lcd_buffer.c **** 
 117:../APP/LCD/Src/lcd_buffer.c ****     LCD_CS_Set();
 118:../APP/LCD/Src/lcd_buffer.c ****     return HAL_OK;
 119:../APP/LCD/Src/lcd_buffer.c **** }
