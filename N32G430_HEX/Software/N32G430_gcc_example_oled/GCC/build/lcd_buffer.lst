  97:../APP/LCD/Src/lcd_buffer.c **** 
  98:../APP/LCD/Src/lcd_buffer.c ****     /* Transfer full screen buffer to LCD via DMA (in chunks) */
  99:../APP/LCD/Src/lcd_buffer.c ****     /* For now, use blocking transfer to avoid complexity */
 100:../APP/LCD/Src/lcd_buffer.c ****     LCD_Address_Set(0, 0, LCD_W - 1, LCD_H - 1);
 101:../APP/LCD/Src/lcd_buffer.c ****     LCD_CS_Clr();
