 202:../APP/Src/oled_driver.c ****     
 203:../APP/Src/oled_driver.c ****     /* 等待DMA传输完成或超时 */
 204:../APP/Src/oled_driver.c ****     while (holed->dma_busy)
 205:../APP/Src/oled_driver.c ****     {
 206:../APP/Src/oled_driver.c ****         /* 检查I2C状态 */
 207:../APP/Src/oled_driver.c ****         if (holed->hi2c->State == HAL_I2C_STATE_READY)
 208:../APP/Src/oled_driver.c ****         {
