  58:../APP/LCD/Src/lcd_test_demo.c **** /**
  59:../APP/LCD/Src/lcd_test_demo.c ****  * @brief LCD test demo main loop
  60:../APP/LCD/Src/lcd_test_demo.c ****  */
  61:../APP/LCD/Src/lcd_test_demo.c **** void LCD_TestDemo_Main(void)
  62:../APP/LCD/Src/lcd_test_demo.c **** {
  63:../APP/LCD/Src/lcd_test_demo.c ****     uint32_t current_time = HAL_GetTick();
  64:../APP/LCD/Src/lcd_test_demo.c **** 
  65:../APP/LCD/Src/lcd_test_demo.c ****     /* Switch test every 3 seconds */
  66:../APP/LCD/Src/lcd_test_demo.c ****     if (current_time - last_switch_time >= 3000)
  67:../APP/LCD/Src/lcd_test_demo.c ****     {
  68:../APP/LCD/Src/lcd_test_demo.c ****         last_switch_time = current_time;
  69:../APP/LCD/Src/lcd_test_demo.c ****         test_state = (LCD_TestState_t)((test_state + 1) % LCD_TEST_COUNT);
  70:../APP/LCD/Src/lcd_test_demo.c ****         color_index = 0;
  71:../APP/LCD/Src/lcd_test_demo.c ****     }
  72:../APP/LCD/Src/lcd_test_demo.c **** 
  73:../APP/LCD/Src/lcd_test_demo.c ****     switch (test_state)
  74:../APP/LCD/Src/lcd_test_demo.c ****     {
  75:../APP/LCD/Src/lcd_test_demo.c ****         case LCD_TEST_COLOR_FILL:
  76:../APP/LCD/Src/lcd_test_demo.c ****             LCD_TestDemo_ColorFill();
  77:../APP/LCD/Src/lcd_test_demo.c ****             break;
  78:../APP/LCD/Src/lcd_test_demo.c **** 
  79:../APP/LCD/Src/lcd_test_demo.c ****         case LCD_TEST_TEXT:
  80:../APP/LCD/Src/lcd_test_demo.c ****             LCD_TestDemo_Text();
  81:../APP/LCD/Src/lcd_test_demo.c ****             break;
  82:../APP/LCD/Src/lcd_test_demo.c **** 
  83:../APP/LCD/Src/lcd_test_demo.c ****         case LCD_TEST_GRAPHICS:
  84:../APP/LCD/Src/lcd_test_demo.c ****             LCD_TestDemo_Graphics();
  85:../APP/LCD/Src/lcd_test_demo.c ****             break;
  86:../APP/LCD/Src/lcd_test_demo.c **** 
  87:../APP/LCD/Src/lcd_test_demo.c ****         default:
  88:../APP/LCD/Src/lcd_test_demo.c ****             test_state = LCD_TEST_COLOR_FILL;
  89:../APP/LCD/Src/lcd_test_demo.c ****             break;
  90:../APP/LCD/Src/lcd_test_demo.c ****     }
  91:../APP/LCD/Src/lcd_test_demo.c **** }
