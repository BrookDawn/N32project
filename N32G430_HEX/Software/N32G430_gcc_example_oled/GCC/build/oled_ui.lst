 367:../APP/Src/oled_ui.c ****     anim->elapsed = 0;
 368:../APP/Src/oled_ui.c ****     anim->state = OLED_ANIM_STOPPED;
 369:../APP/Src/oled_ui.c ****     anim->easing = (easing != NULL) ? easing : OLED_Easing_Linear;
