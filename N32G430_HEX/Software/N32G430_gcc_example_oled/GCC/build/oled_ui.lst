 225:../APP/Src/oled_ui.c **** void OLED_UI_DrawCircle(OLED_UIContext_t *ctx, uint8_t x, uint8_t y, 
 226:../APP/Src/oled_ui.c ****                         uint8_t r, uint8_t color)
 227:../APP/Src/oled_ui.c **** {
 228:../APP/Src/oled_ui.c ****     int16_t f = 1 - r;
 229:../APP/Src/oled_ui.c ****     int16_t ddF_x = 1;
 230:../APP/Src/oled_ui.c ****     int16_t ddF_y = -2 * r;
 231:../APP/Src/oled_ui.c ****     int16_t px = 0;
