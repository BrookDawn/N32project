  35:../APP/Src/oled_ui.c **** /**
  36:../APP/Src/oled_ui.c ****   * @brief  检查点是否在裁剪区域内
  37:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
  38:../APP/Src/oled_ui.c ****   * @param  x: X坐标
  39:../APP/Src/oled_ui.c ****   * @param  y: Y坐标
  40:../APP/Src/oled_ui.c ****   * @retval true=在区域内，false=不在区域内
  41:../APP/Src/oled_ui.c ****   */
  42:../APP/Src/oled_ui.c **** static bool OLED_UI_IsInClip(OLED_UIContext_t *ctx, uint8_t x, uint8_t y)
  43:../APP/Src/oled_ui.c **** {
  44:../APP/Src/oled_ui.c ****     if (!ctx->clip_enabled)
  45:../APP/Src/oled_ui.c ****     {
  46:../APP/Src/oled_ui.c ****         return true;
  47:../APP/Src/oled_ui.c ****     }
  48:../APP/Src/oled_ui.c ****     
  49:../APP/Src/oled_ui.c ****     return (x >= ctx->clip_x && x < (ctx->clip_x + ctx->clip_w) &&
  50:../APP/Src/oled_ui.c ****             y >= ctx->clip_y && y < (ctx->clip_y + ctx->clip_h));
  51:../APP/Src/oled_ui.c **** }
  52:../APP/Src/oled_ui.c **** 
  53:../APP/Src/oled_ui.c **** /* Public functions ----------------------------------------------------------*/
  54:../APP/Src/oled_ui.c **** 
  55:../APP/Src/oled_ui.c **** /**
  56:../APP/Src/oled_ui.c ****   * @brief  开始绘制（设置裁剪区域）
  57:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
  58:../APP/Src/oled_ui.c ****   * @param  holed: OLED句柄指针
  59:../APP/Src/oled_ui.c ****   * @param  x: X坐标
  60:../APP/Src/oled_ui.c ****   * @param  y: Y坐标
  61:../APP/Src/oled_ui.c ****   * @param  w: 宽度
  62:../APP/Src/oled_ui.c ****   * @param  h: 高度
  63:../APP/Src/oled_ui.c ****   */
  64:../APP/Src/oled_ui.c **** void OLED_UI_Begin(OLED_UIContext_t *ctx, OLED_HandleTypeDef *holed, 
  65:../APP/Src/oled_ui.c ****                    uint8_t x, uint8_t y, uint8_t w, uint8_t h)
  66:../APP/Src/oled_ui.c **** {
  67:../APP/Src/oled_ui.c ****     if (ctx == NULL || holed == NULL)
  68:../APP/Src/oled_ui.c ****     {
  69:../APP/Src/oled_ui.c ****         return;
  70:../APP/Src/oled_ui.c ****     }
  71:../APP/Src/oled_ui.c ****     
  72:../APP/Src/oled_ui.c ****     ctx->holed = holed;
  73:../APP/Src/oled_ui.c ****     ctx->clip_x = x;
  74:../APP/Src/oled_ui.c ****     ctx->clip_y = y;
  75:../APP/Src/oled_ui.c ****     ctx->clip_w = w;
  76:../APP/Src/oled_ui.c ****     ctx->clip_h = h;
  77:../APP/Src/oled_ui.c ****     ctx->clip_enabled = true;
  78:../APP/Src/oled_ui.c **** }
  79:../APP/Src/oled_ui.c **** 
  80:../APP/Src/oled_ui.c **** /**
  81:../APP/Src/oled_ui.c ****   * @brief  结束绘制（清除裁剪区域）
  82:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
  83:../APP/Src/oled_ui.c ****   */
  84:../APP/Src/oled_ui.c **** void OLED_UI_End(OLED_UIContext_t *ctx)
  85:../APP/Src/oled_ui.c **** {
  86:../APP/Src/oled_ui.c ****     if (ctx == NULL)
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccD06rue.s 			page 3


  87:../APP/Src/oled_ui.c ****     {
  88:../APP/Src/oled_ui.c ****         return;
  89:../APP/Src/oled_ui.c ****     }
  90:../APP/Src/oled_ui.c ****     
  91:../APP/Src/oled_ui.c ****     ctx->clip_enabled = false;
  92:../APP/Src/oled_ui.c **** }
  93:../APP/Src/oled_ui.c **** 
  94:../APP/Src/oled_ui.c **** /**
  95:../APP/Src/oled_ui.c ****   * @brief  绘制像素点（带裁剪）
  96:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
