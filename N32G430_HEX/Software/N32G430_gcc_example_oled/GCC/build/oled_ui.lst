 355:../APP/Src/oled_ui.c **** void OLED_UI_AnimInit(OLED_Animation_t *anim, float start, float end, 
 356:../APP/Src/oled_ui.c ****                       uint32_t duration, OLED_EasingFunc_t easing)
 357:../APP/Src/oled_ui.c **** {
 358:../APP/Src/oled_ui.c ****     if (anim == NULL)
 359:../APP/Src/oled_ui.c ****     {
 360:../APP/Src/oled_ui.c ****         return;
 361:../APP/Src/oled_ui.c ****     }
 362:../APP/Src/oled_ui.c ****     
 363:../APP/Src/oled_ui.c ****     anim->start_value = start;
 364:../APP/Src/oled_ui.c ****     anim->end_value = end;
 365:../APP/Src/oled_ui.c ****     anim->current_value = start;
