  98:../APP/Src/oled_ui.c ****   * @param  y: Y坐标
  99:../APP/Src/oled_ui.c ****   * @param  color: 颜色
 100:../APP/Src/oled_ui.c ****   */
 101:../APP/Src/oled_ui.c **** void OLED_UI_DrawPixel(OLED_UIContext_t *ctx, uint8_t x, uint8_t y, uint8_t color)
 102:../APP/Src/oled_ui.c **** {
 103:../APP/Src/oled_ui.c ****     if (ctx == NULL || ctx->holed == NULL)
 104:../APP/Src/oled_ui.c ****     {
 105:../APP/Src/oled_ui.c ****         return;
 106:../APP/Src/oled_ui.c ****     }
 107:../APP/Src/oled_ui.c ****     
 108:../APP/Src/oled_ui.c ****     if (OLED_UI_IsInClip(ctx, x, y))
 109:../APP/Src/oled_ui.c ****     {
 110:../APP/Src/oled_ui.c ****         OLED_SetPixel(ctx->holed, x, y, color);
 111:../APP/Src/oled_ui.c ****     }
 112:../APP/Src/oled_ui.c **** }
 113:../APP/Src/oled_ui.c **** 
 114:../APP/Src/oled_ui.c **** /**
 115:../APP/Src/oled_ui.c ****   * @brief  绘制线条（Bresenham算法）
 116:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
 117:../APP/Src/oled_ui.c ****   * @param  x1: 起点X坐标
 118:../APP/Src/oled_ui.c ****   * @param  y1: 起点Y坐标
 119:../APP/Src/oled_ui.c ****   * @param  x2: 终点X坐标
 120:../APP/Src/oled_ui.c ****   * @param  y2: 终点Y坐标
 121:../APP/Src/oled_ui.c ****   * @param  color: 颜色
 122:../APP/Src/oled_ui.c ****   */
 123:../APP/Src/oled_ui.c **** void OLED_UI_DrawLine(OLED_UIContext_t *ctx, uint8_t x1, uint8_t y1, 
 124:../APP/Src/oled_ui.c ****                       uint8_t x2, uint8_t y2, uint8_t color)
 125:../APP/Src/oled_ui.c **** {
 126:../APP/Src/oled_ui.c ****     int16_t dx, dy, sx, sy, err, e2;
 127:../APP/Src/oled_ui.c ****     
 128:../APP/Src/oled_ui.c ****     if (ctx == NULL || ctx->holed == NULL)
 129:../APP/Src/oled_ui.c ****     {
 130:../APP/Src/oled_ui.c ****         return;
 131:../APP/Src/oled_ui.c ****     }
 132:../APP/Src/oled_ui.c ****     
 133:../APP/Src/oled_ui.c ****     dx = (x2 > x1) ? (x2 - x1) : (x1 - x2);
 134:../APP/Src/oled_ui.c ****     dy = (y2 > y1) ? (y2 - y1) : (y1 - y2);
 135:../APP/Src/oled_ui.c ****     sx = (x1 < x2) ? 1 : -1;
 136:../APP/Src/oled_ui.c ****     sy = (y1 < y2) ? 1 : -1;
 137:../APP/Src/oled_ui.c ****     err = dx - dy;
 138:../APP/Src/oled_ui.c ****     
 139:../APP/Src/oled_ui.c ****     while (1)
 140:../APP/Src/oled_ui.c ****     {
 141:../APP/Src/oled_ui.c ****         OLED_UI_DrawPixel(ctx, x1, y1, color);
 142:../APP/Src/oled_ui.c ****         
 143:../APP/Src/oled_ui.c ****         if (x1 == x2 && y1 == y2)
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccD06rue.s 			page 4


 144:../APP/Src/oled_ui.c ****         {
 145:../APP/Src/oled_ui.c ****             break;
 146:../APP/Src/oled_ui.c ****         }
 147:../APP/Src/oled_ui.c ****         
 148:../APP/Src/oled_ui.c ****         e2 = 2 * err;
 149:../APP/Src/oled_ui.c ****         if (e2 > -dy)
 150:../APP/Src/oled_ui.c ****         {
 151:../APP/Src/oled_ui.c ****             err -= dy;
 152:../APP/Src/oled_ui.c ****             x1 += sx;
 153:../APP/Src/oled_ui.c ****         }
 154:../APP/Src/oled_ui.c ****         if (e2 < dx)
 155:../APP/Src/oled_ui.c ****         {
 156:../APP/Src/oled_ui.c ****             err += dx;
 157:../APP/Src/oled_ui.c ****             y1 += sy;
 158:../APP/Src/oled_ui.c ****         }
 159:../APP/Src/oled_ui.c ****     }
 160:../APP/Src/oled_ui.c **** }
 161:../APP/Src/oled_ui.c **** 
 162:../APP/Src/oled_ui.c **** /**
