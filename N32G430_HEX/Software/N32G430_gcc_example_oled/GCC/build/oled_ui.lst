 170:../APP/Src/oled_ui.c ****   */
 171:../APP/Src/oled_ui.c **** void OLED_UI_DrawBox(OLED_UIContext_t *ctx, uint8_t x, uint8_t y, 
 172:../APP/Src/oled_ui.c ****                      uint8_t w, uint8_t h, uint8_t color)
 173:../APP/Src/oled_ui.c **** {
 174:../APP/Src/oled_ui.c ****     if (ctx == NULL || ctx->holed == NULL)
 175:../APP/Src/oled_ui.c ****     {
 176:../APP/Src/oled_ui.c ****         return;
 177:../APP/Src/oled_ui.c ****     }
 178:../APP/Src/oled_ui.c ****     
 179:../APP/Src/oled_ui.c ****     /* 上边 */
 180:../APP/Src/oled_ui.c ****     OLED_UI_DrawLine(ctx, x, y, x + w - 1, y, color);
 181:../APP/Src/oled_ui.c ****     /* 下边 */
 182:../APP/Src/oled_ui.c ****     OLED_UI_DrawLine(ctx, x, y + h - 1, x + w - 1, y + h - 1, color);
 183:../APP/Src/oled_ui.c ****     /* 左边 */
 184:../APP/Src/oled_ui.c ****     OLED_UI_DrawLine(ctx, x, y, x, y + h - 1, color);
 185:../APP/Src/oled_ui.c ****     /* 右边 */
 186:../APP/Src/oled_ui.c ****     OLED_UI_DrawLine(ctx, x + w - 1, y, x + w - 1, y + h - 1, color);
 187:../APP/Src/oled_ui.c **** }
 188:../APP/Src/oled_ui.c **** 
 189:../APP/Src/oled_ui.c **** /**
 190:../APP/Src/oled_ui.c ****   * @brief  填充矩形
 191:../APP/Src/oled_ui.c ****   * @param  ctx: UI上下文指针
 192:../APP/Src/oled_ui.c ****   * @param  x: 左上角X坐标
