 374:../APP/Src/oled_ui.c **** /**
 375:../APP/Src/oled_ui.c ****   * @brief  更新动画
 376:../APP/Src/oled_ui.c ****   * @param  anim: 动画结构体指针
 377:../APP/Src/oled_ui.c ****   * @param  delta_ms: 时间增量（毫秒）
 378:../APP/Src/oled_ui.c ****   * @retval true=动画完成，false=动画进行中
 379:../APP/Src/oled_ui.c ****   */
 380:../APP/Src/oled_ui.c **** bool OLED_UI_AnimUpdate(OLED_Animation_t *anim, uint32_t delta_ms)
 381:../APP/Src/oled_ui.c **** {
 382:../APP/Src/oled_ui.c ****     float t;
 383:../APP/Src/oled_ui.c ****     float range;
 384:../APP/Src/oled_ui.c ****     
 385:../APP/Src/oled_ui.c ****     if (anim == NULL || anim->state != OLED_ANIM_PLAYING)
 386:../APP/Src/oled_ui.c ****     {
 387:../APP/Src/oled_ui.c ****         return true;
 388:../APP/Src/oled_ui.c ****     }
 389:../APP/Src/oled_ui.c ****     
 390:../APP/Src/oled_ui.c ****     anim->elapsed += delta_ms;
 391:../APP/Src/oled_ui.c ****     
 392:../APP/Src/oled_ui.c ****     if (anim->elapsed >= anim->duration)
 393:../APP/Src/oled_ui.c ****     {
 394:../APP/Src/oled_ui.c ****         if (anim->loop)
 395:../APP/Src/oled_ui.c ****         {
 396:../APP/Src/oled_ui.c ****             if (anim->reverse)
 397:../APP/Src/oled_ui.c ****             {
 398:../APP/Src/oled_ui.c ****                 /* 反向循环 */
 399:../APP/Src/oled_ui.c ****                 float temp = anim->start_value;
 400:../APP/Src/oled_ui.c ****                 anim->start_value = anim->end_value;
 401:../APP/Src/oled_ui.c ****                 anim->end_value = temp;
 402:../APP/Src/oled_ui.c ****             }
 403:../APP/Src/oled_ui.c ****             anim->elapsed = 0;
 404:../APP/Src/oled_ui.c ****             anim->current_value = anim->start_value;
 405:../APP/Src/oled_ui.c ****             return false;
 406:../APP/Src/oled_ui.c ****         }
 407:../APP/Src/oled_ui.c ****         else
 408:../APP/Src/oled_ui.c ****         {
 409:../APP/Src/oled_ui.c ****             anim->elapsed = anim->duration;
 410:../APP/Src/oled_ui.c ****             anim->current_value = anim->end_value;
 411:../APP/Src/oled_ui.c ****             anim->state = OLED_ANIM_STOPPED;
 412:../APP/Src/oled_ui.c ****             return true;
 413:../APP/Src/oled_ui.c ****         }
 414:../APP/Src/oled_ui.c ****     }
 415:../APP/Src/oled_ui.c ****     
 416:../APP/Src/oled_ui.c ****     t = (float)anim->elapsed / (float)anim->duration;
 417:../APP/Src/oled_ui.c ****     if (t > 1.0f) t = 1.0f;
 418:../APP/Src/oled_ui.c ****     
 419:../APP/Src/oled_ui.c ****     if (anim->easing != NULL)
 420:../APP/Src/oled_ui.c ****     {
 421:../APP/Src/oled_ui.c ****         t = anim->easing(t);
 422:../APP/Src/oled_ui.c ****     }
 423:../APP/Src/oled_ui.c ****     
 424:../APP/Src/oled_ui.c ****     range = anim->end_value - anim->start_value;
 425:../APP/Src/oled_ui.c ****     anim->current_value = anim->start_value + range * t;
 426:../APP/Src/oled_ui.c ****     
 427:../APP/Src/oled_ui.c ****     return false;
 428:../APP/Src/oled_ui.c **** }
