 291:../APP/LCD/Src/lcd_advanced_demo.c ****     anim_frame++;
 292:../APP/LCD/Src/lcd_advanced_demo.c **** 
 293:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Moving rectangles - erase old, draw new */
 294:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < 5; i++) {
 295:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old rectangle */
 296:../APP/LCD/Src/lcd_advanced_demo.c ****         if (anim_frame > 1) {
 297:../APP/LCD/Src/lcd_advanced_demo.c ****             LCD_Fill(prev_rect_x[i], 10 + i * 15, prev_rect_x[i] + 15, 20 + i * 15, BLACK);
 298:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 299:../APP/LCD/Src/lcd_advanced_demo.c **** 
 300:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Draw new rectangle */
 301:../APP/LCD/Src/lcd_advanced_demo.c ****         uint16_t x = (anim_frame * 2 + i * 20) % (LCD_W - 15);
 302:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(x, 10 + i * 15, x + 15, 20 + i * 15, rainbow_colors[i]);
 303:../APP/LCD/Src/lcd_advanced_demo.c ****         prev_rect_x[i] = x;
 304:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 305:../APP/LCD/Src/lcd_advanced_demo.c **** 
 306:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Rotating lines - erase old, draw new */
 307:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < 8; i++) {
 308:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old line */
 309:../APP/LCD/Src/lcd_advanced_demo.c ****         if (anim_frame > 1) {
 310:../APP/LCD/Src/lcd_advanced_demo.c ****             LCD_DrawLine(LCD_W / 2, 80, prev_line_x2[i], prev_line_y2[i], BLACK);
 311:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 312:../APP/LCD/Src/lcd_advanced_demo.c **** 
 313:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Draw new line */
 314:../APP/LCD/Src/lcd_advanced_demo.c ****         float angle = (anim_frame * 2 + i * 45) * 0.01745f;
 315:../APP/LCD/Src/lcd_advanced_demo.c ****         int x2 = LCD_W / 2 + (int)(fast_cos(angle) * 30);
 316:../APP/LCD/Src/lcd_advanced_demo.c ****         int y2 = 80 + (int)(fast_sin(angle) * 30);
 317:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_DrawLine(LCD_W / 2, 80, x2, y2, rainbow_colors[i]);
 318:../APP/LCD/Src/lcd_advanced_demo.c ****         prev_line_x2[i] = x2;
 319:../APP/LCD/Src/lcd_advanced_demo.c ****         prev_line_y2[i] = y2;
 320:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 321:../APP/LCD/Src/lcd_advanced_demo.c **** 
 322:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Growing circles - erase old, draw new */
 323:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < 3; i++) {
 324:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old circle */
 325:../APP/LCD/Src/lcd_advanced_demo.c ****         if (anim_frame > 1 && prev_circle_r[i] > 0) {
 326:../APP/LCD/Src/lcd_advanced_demo.c ****             Draw_Circle(30 + i * 35, 130, prev_circle_r[i], BLACK);
 327:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 328:../APP/LCD/Src/lcd_advanced_demo.c **** 
 329:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Draw new circle */
 330:../APP/LCD/Src/lcd_advanced_demo.c ****         uint8_t r = ((anim_frame + i * 20) % 40) / 2;
 331:../APP/LCD/Src/lcd_advanced_demo.c ****         Draw_Circle(30 + i * 35, 130, r, rainbow_colors[i * 2]);
 332:../APP/LCD/Src/lcd_advanced_demo.c ****         prev_circle_r[i] = r;
 333:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 334:../APP/LCD/Src/lcd_advanced_demo.c **** }
