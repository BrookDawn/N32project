 276:../APP/LCD/Src/lcd_advanced_demo.c **** static void demo_graphics_test(void) {
 277:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint32_t anim_frame = 0;
 278:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint16_t prev_rect_x[5] = {0};
 279:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint16_t prev_line_x2[8] = {0};
 280:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint16_t prev_line_y2[8] = {0};
 281:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint8_t prev_circle_r[3] = {0};
 282:../APP/LCD/Src/lcd_advanced_demo.c **** 
 283:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Clear screen only once */
 284:../APP/LCD/Src/lcd_advanced_demo.c ****     if (!demo_ctx.graphics_initialized) {
 285:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(0, 0, LCD_W, LCD_H, BLACK);
 286:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(5, 5, (const u8 *)"Graphics Test", WHITE, BLACK, 12, 0);
 287:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.graphics_initialized = true;
 288:../APP/LCD/Src/lcd_advanced_demo.c ****         anim_frame = 0;  /* Reset animation */
 289:../APP/LCD/Src/lcd_advanced_demo.c ****     }
