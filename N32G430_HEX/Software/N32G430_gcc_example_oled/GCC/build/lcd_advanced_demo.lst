 337:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Performance metrics display with partial refresh
 338:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 339:../APP/LCD/Src/lcd_advanced_demo.c **** static void demo_performance(void) {
 340:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint32_t last_update = 0;
 341:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint32_t prev_fps = 0;
 342:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint16_t prev_bar_width = 0;
 343:../APP/LCD/Src/lcd_advanced_demo.c ****     static bool initialized = false;
 344:../APP/LCD/Src/lcd_advanced_demo.c ****     uint32_t current_time = HAL_GetTick();
 345:../APP/LCD/Src/lcd_advanced_demo.c **** 
 346:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Initialize only once */
 347:../APP/LCD/Src/lcd_advanced_demo.c ****     if (!initialized) {
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccCmWBDU.s 			page 14


 348:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(0, 0, LCD_W, LCD_H, BLACK);
 349:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(10, 10, (const u8 *)"Performance Test", YELLOW, BLACK, 16, 0);
 350:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(10, 60, (const u8 *)"LCD: 128x160", CYAN, BLACK, 12, 0);
 351:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(10, 80, (const u8 *)"SPI DMA: ON", MAGENTA, BLACK, 12, 0);
 352:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(10, 100, (const u8 *)"Partial Refresh", MAGENTA, BLACK, 12, 0);
 353:../APP/LCD/Src/lcd_advanced_demo.c ****         initialized = true;
 354:../APP/LCD/Src/lcd_advanced_demo.c ****         last_update = current_time;
 355:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 356:../APP/LCD/Src/lcd_advanced_demo.c **** 
 357:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Update FPS display only every 500ms to reduce overhead */
 358:../APP/LCD/Src/lcd_advanced_demo.c ****     if (current_time - last_update >= 500 && demo_ctx.fps != prev_fps) {
 359:../APP/LCD/Src/lcd_advanced_demo.c ****         char fps_str[32];
 360:../APP/LCD/Src/lcd_advanced_demo.c **** 
 361:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old FPS text area */
 362:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(10, 35, 120, 50, BLACK);
 363:../APP/LCD/Src/lcd_advanced_demo.c **** 
 364:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Draw new FPS */
 365:../APP/LCD/Src/lcd_advanced_demo.c ****         sprintf(fps_str, "FPS: %lu", demo_ctx.fps);
 366:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(10, 35, (const u8 *)fps_str, GREEN, BLACK, 16, 0);
 367:../APP/LCD/Src/lcd_advanced_demo.c **** 
 368:../APP/LCD/Src/lcd_advanced_demo.c ****         prev_fps = demo_ctx.fps;
 369:../APP/LCD/Src/lcd_advanced_demo.c ****         last_update = current_time;
 370:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 371:../APP/LCD/Src/lcd_advanced_demo.c **** 
 372:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Animated progress bar - update every 3 frames to reduce overhead */
 373:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint32_t bar_anim = 0;
 374:../APP/LCD/Src/lcd_advanced_demo.c ****     static uint8_t frame_skip = 0;
 375:../APP/LCD/Src/lcd_advanced_demo.c **** 
 376:../APP/LCD/Src/lcd_advanced_demo.c ****     frame_skip++;
 377:../APP/LCD/Src/lcd_advanced_demo.c ****     if (frame_skip >= 3) {
 378:../APP/LCD/Src/lcd_advanced_demo.c ****         frame_skip = 0;
 379:../APP/LCD/Src/lcd_advanced_demo.c ****         bar_anim++;
 380:../APP/LCD/Src/lcd_advanced_demo.c **** 
 381:../APP/LCD/Src/lcd_advanced_demo.c ****         uint16_t bar_width = (bar_anim % 100) * (LCD_W - 20) / 100;
 382:../APP/LCD/Src/lcd_advanced_demo.c **** 
 383:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Only redraw bar if width changed significantly */
 384:../APP/LCD/Src/lcd_advanced_demo.c ****         if (bar_width != prev_bar_width) {
 385:../APP/LCD/Src/lcd_advanced_demo.c ****             /* Erase old bar end */
 386:../APP/LCD/Src/lcd_advanced_demo.c ****             if (prev_bar_width > bar_width) {
 387:../APP/LCD/Src/lcd_advanced_demo.c ****                 LCD_Fill(10 + bar_width, 120, 10 + prev_bar_width, 130, GRAYBLUE);
 388:../APP/LCD/Src/lcd_advanced_demo.c ****             }
 389:../APP/LCD/Src/lcd_advanced_demo.c ****             /* Draw new bar portion */
 390:../APP/LCD/Src/lcd_advanced_demo.c ****             LCD_Fill(10 + prev_bar_width, 120, 10 + bar_width, 130, GREEN);
 391:../APP/LCD/Src/lcd_advanced_demo.c ****             prev_bar_width = bar_width;
 392:../APP/LCD/Src/lcd_advanced_demo.c **** 
 393:../APP/LCD/Src/lcd_advanced_demo.c ****             /* Redraw background when bar resets */
 394:../APP/LCD/Src/lcd_advanced_demo.c ****             if (bar_width < 5 && prev_bar_width > 90) {
 395:../APP/LCD/Src/lcd_advanced_demo.c ****                 LCD_Fill(10, 120, LCD_W - 10, 130, GRAYBLUE);
 396:../APP/LCD/Src/lcd_advanced_demo.c ****             }
 397:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 398:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 399:../APP/LCD/Src/lcd_advanced_demo.c **** }
