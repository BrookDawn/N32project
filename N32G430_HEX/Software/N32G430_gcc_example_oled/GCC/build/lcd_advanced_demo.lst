 119:../APP/LCD/Src/lcd_advanced_demo.c **** /**
 120:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Update and draw bouncing balls with partial refresh
 121:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 122:../APP/LCD/Src/lcd_advanced_demo.c **** static void demo_bouncing_balls(void) {
 123:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Clear screen and draw title only once */
 124:../APP/LCD/Src/lcd_advanced_demo.c ****     if (!demo_ctx.balls_initialized) {
 125:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(0, 0, LCD_W, LCD_H, BLACK);
 126:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(5, 5, (const u8 *)"Bouncing Balls", WHITE, BLACK, 12, 0);
 127:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls_initialized = true;
 128:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 129:../APP/LCD/Src/lcd_advanced_demo.c **** 
 130:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < MAX_BALLS; i++) {
 131:../APP/LCD/Src/lcd_advanced_demo.c ****         Ball_t *ball = &demo_ctx.balls[i];
 132:../APP/LCD/Src/lcd_advanced_demo.c **** 
 133:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old position */
 134:../APP/LCD/Src/lcd_advanced_demo.c ****         Draw_Circle((uint16_t)ball->prev_x, (uint16_t)ball->prev_y, ball->radius + 1, BLACK);
 135:../APP/LCD/Src/lcd_advanced_demo.c **** 
 136:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Save current position */
 137:../APP/LCD/Src/lcd_advanced_demo.c ****         ball->prev_x = ball->x;
 138:../APP/LCD/Src/lcd_advanced_demo.c ****         ball->prev_y = ball->y;
 139:../APP/LCD/Src/lcd_advanced_demo.c **** 
 140:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Update position */
 141:../APP/LCD/Src/lcd_advanced_demo.c ****         ball->x += ball->vx;
 142:../APP/LCD/Src/lcd_advanced_demo.c ****         ball->y += ball->vy;
 143:../APP/LCD/Src/lcd_advanced_demo.c **** 
 144:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Bounce off walls */
 145:../APP/LCD/Src/lcd_advanced_demo.c ****         if (ball->x - ball->radius < 0 || ball->x + ball->radius >= LCD_W) {
 146:../APP/LCD/Src/lcd_advanced_demo.c ****             ball->vx = -ball->vx;
 147:../APP/LCD/Src/lcd_advanced_demo.c ****             ball->x = (ball->x < LCD_W / 2) ? ball->radius : LCD_W - ball->radius - 1;
 148:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 149:../APP/LCD/Src/lcd_advanced_demo.c ****         if (ball->y - ball->radius < 0 || ball->y + ball->radius >= LCD_H) {
 150:../APP/LCD/Src/lcd_advanced_demo.c ****             ball->vy = -ball->vy;
 151:../APP/LCD/Src/lcd_advanced_demo.c ****             ball->y = (ball->y < LCD_H / 2) ? ball->radius : LCD_H - ball->radius - 1;
 152:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 153:../APP/LCD/Src/lcd_advanced_demo.c **** 
 154:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Draw ball at new position */
 155:../APP/LCD/Src/lcd_advanced_demo.c ****         Draw_Circle((uint16_t)ball->x, (uint16_t)ball->y, ball->radius, ball->color);
 156:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 157:../APP/LCD/Src/lcd_advanced_demo.c **** }
 158:../APP/LCD/Src/lcd_advanced_demo.c **** 
 159:../APP/LCD/Src/lcd_advanced_demo.c **** /**
 160:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Plasma effect demo (simplified for performance)
 161:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 162:../APP/LCD/Src/lcd_advanced_demo.c **** static void demo_plasma_effect(void) {
 163:../APP/LCD/Src/lcd_advanced_demo.c ****     demo_ctx.plasma_time++;
 164:../APP/LCD/Src/lcd_advanced_demo.c **** 
 165:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Draw simplified plasma pattern */
 166:../APP/LCD/Src/lcd_advanced_demo.c ****     for (uint16_t y = 0; y < LCD_H; y += 2) {
 167:../APP/LCD/Src/lcd_advanced_demo.c ****         for (uint16_t x = 0; x < LCD_W; x += 2) {
 168:../APP/LCD/Src/lcd_advanced_demo.c ****             float cx = (x - LCD_W/2) / 20.0f;
 169:../APP/LCD/Src/lcd_advanced_demo.c ****             float cy = (y - LCD_H/2) / 20.0f;
 170:../APP/LCD/Src/lcd_advanced_demo.c **** 
 171:../APP/LCD/Src/lcd_advanced_demo.c ****             float v = fast_sin(cx + demo_ctx.plasma_time * 0.1f) +
 172:../APP/LCD/Src/lcd_advanced_demo.c ****                       fast_sin(cy + demo_ctx.plasma_time * 0.08f);
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccCmWBDU.s 			page 6


 173:../APP/LCD/Src/lcd_advanced_demo.c **** 
 174:../APP/LCD/Src/lcd_advanced_demo.c ****             int color_idx = ((int)(v * 2.0f) + demo_ctx.plasma_time / 10) % RAINBOW_SIZE;
 175:../APP/LCD/Src/lcd_advanced_demo.c ****             if (color_idx < 0) color_idx += RAINBOW_SIZE;
 176:../APP/LCD/Src/lcd_advanced_demo.c **** 
 177:../APP/LCD/Src/lcd_advanced_demo.c ****             LCD_DrawPoint(x, y, rainbow_colors[color_idx]);
 178:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 179:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 180:../APP/LCD/Src/lcd_advanced_demo.c **** 
 181:../APP/LCD/Src/lcd_advanced_demo.c ****     LCD_ShowString(5, 5, (const u8 *)"Plasma Effect", WHITE, BLACK, 12, 0);
 182:../APP/LCD/Src/lcd_advanced_demo.c **** }
