 194:../APP/LCD/Src/lcd_advanced_demo.c **** /**
 195:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Spawn a new particle
 196:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 197:../APP/LCD/Src/lcd_advanced_demo.c **** static void spawn_particle(float x, float y) {
 198:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < MAX_PARTICLES; i++) {
 199:../APP/LCD/Src/lcd_advanced_demo.c ****         if (!demo_ctx.particles[i].active) {
 200:../APP/LCD/Src/lcd_advanced_demo.c ****             Particle_t *p = &demo_ctx.particles[i];
 201:../APP/LCD/Src/lcd_advanced_demo.c ****             p->x = x;
 202:../APP/LCD/Src/lcd_advanced_demo.c ****             p->y = y;
 203:../APP/LCD/Src/lcd_advanced_demo.c ****             p->prev_x = x;
 204:../APP/LCD/Src/lcd_advanced_demo.c ****             p->prev_y = y;
 205:../APP/LCD/Src/lcd_advanced_demo.c ****             p->vx = randf(-3.0f, 3.0f);
 206:../APP/LCD/Src/lcd_advanced_demo.c ****             p->vy = randf(-4.0f, -1.0f);
 207:../APP/LCD/Src/lcd_advanced_demo.c ****             p->color = random_color();
 208:../APP/LCD/Src/lcd_advanced_demo.c ****             p->life = 60;
 209:../APP/LCD/Src/lcd_advanced_demo.c ****             p->active = true;
 210:../APP/LCD/Src/lcd_advanced_demo.c ****             break;
 211:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 212:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 213:../APP/LCD/Src/lcd_advanced_demo.c **** }
 214:../APP/LCD/Src/lcd_advanced_demo.c **** 
 215:../APP/LCD/Src/lcd_advanced_demo.c **** /**
 216:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Particle effect demo with partial refresh
 217:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 218:../APP/LCD/Src/lcd_advanced_demo.c **** static void demo_particles(void) {
 219:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Clear screen only once */
 220:../APP/LCD/Src/lcd_advanced_demo.c ****     if (!demo_ctx.particles_initialized) {
 221:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_Fill(0, 0, LCD_W, LCD_H, BLACK);
 222:../APP/LCD/Src/lcd_advanced_demo.c ****         LCD_ShowString(5, 5, (const u8 *)"Particle Fountain", WHITE, BLACK, 12, 0);
 223:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.particles_initialized = true;
 224:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 225:../APP/LCD/Src/lcd_advanced_demo.c **** 
 226:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Spawn particles from bottom center */
 227:../APP/LCD/Src/lcd_advanced_demo.c ****     demo_ctx.particle_spawn_timer++;
 228:../APP/LCD/Src/lcd_advanced_demo.c ****     if (demo_ctx.particle_spawn_timer >= 3) {
 229:../APP/LCD/Src/lcd_advanced_demo.c ****         spawn_particle(LCD_W / 2.0f, LCD_H - 5.0f);
 230:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.particle_spawn_timer = 0;
 231:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 232:../APP/LCD/Src/lcd_advanced_demo.c **** 
 233:../APP/LCD/Src/lcd_advanced_demo.c ****     /* Update and draw particles */
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccCmWBDU.s 			page 12


 234:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < MAX_PARTICLES; i++) {
 235:../APP/LCD/Src/lcd_advanced_demo.c ****         Particle_t *p = &demo_ctx.particles[i];
 236:../APP/LCD/Src/lcd_advanced_demo.c ****         if (!p->active) continue;
 237:../APP/LCD/Src/lcd_advanced_demo.c **** 
 238:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Erase old position */
 239:../APP/LCD/Src/lcd_advanced_demo.c ****         if (p->prev_x >= 0 && p->prev_x < LCD_W && p->prev_y >= 0 && p->prev_y < LCD_H) {
 240:../APP/LCD/Src/lcd_advanced_demo.c ****             LCD_DrawPoint((uint16_t)p->prev_x, (uint16_t)p->prev_y, BLACK);
 241:../APP/LCD/Src/lcd_advanced_demo.c ****             if (p->life > 10) {
 242:../APP/LCD/Src/lcd_advanced_demo.c ****                 LCD_DrawPoint((uint16_t)p->prev_x + 1, (uint16_t)p->prev_y, BLACK);
 243:../APP/LCD/Src/lcd_advanced_demo.c ****                 LCD_DrawPoint((uint16_t)p->prev_x, (uint16_t)p->prev_y + 1, BLACK);
 244:../APP/LCD/Src/lcd_advanced_demo.c ****             }
 245:../APP/LCD/Src/lcd_advanced_demo.c ****         }
 246:../APP/LCD/Src/lcd_advanced_demo.c **** 
 247:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Save old position */
 248:../APP/LCD/Src/lcd_advanced_demo.c ****         p->prev_x = p->x;
 249:../APP/LCD/Src/lcd_advanced_demo.c ****         p->prev_y = p->y;
 250:../APP/LCD/Src/lcd_advanced_demo.c **** 
 251:../APP/LCD/Src/lcd_advanced_demo.c ****         /* Update physics */
 252:../APP/LCD/Src/lcd_advanced_demo.c ****         p->vy += 0.2f;  /* Gravity */
 253:../APP/LCD/Src/lcd_advanced_demo.c ****         p->x += p->vx;
 254:../APP/LCD/Src/lcd_advanced_demo.c ****         p->y += p->vy;
 255:../APP/LCD/Src/lcd_advanced_demo.c ****         p->life--;
 256:../APP/LCD/Src/lcd_advanced_demo.c **** 
 257:../APP/LCD/Src/lcd_advanced_demo.c ****         if (p->life == 0 || p->y >= LCD_H) {
 258:../APP/LCD/Src/lcd_advanced_demo.c ****             p->active = false;
 259:../APP/LCD/Src/lcd_advanced_demo.c ****             continue;
