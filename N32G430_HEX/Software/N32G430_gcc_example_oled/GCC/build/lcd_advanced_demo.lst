 103:../APP/LCD/Src/lcd_advanced_demo.c **** /**
 104:../APP/LCD/Src/lcd_advanced_demo.c ****  * @brief Initialize bouncing balls
 105:../APP/LCD/Src/lcd_advanced_demo.c ****  */
 106:../APP/LCD/Src/lcd_advanced_demo.c **** static void init_balls(void) {
 107:../APP/LCD/Src/lcd_advanced_demo.c ****     for (int i = 0; i < MAX_BALLS; i++) {
 108:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].x = randf(10, LCD_W - 10);
 109:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].y = randf(10, LCD_H - 10);
 110:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].prev_x = demo_ctx.balls[i].x;
 111:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].prev_y = demo_ctx.balls[i].y;
 112:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].vx = randf(-2.0f, 2.0f);
 113:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].vy = randf(-2.0f, 2.0f);
 114:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].radius = 5 + (i * 2);
 115:../APP/LCD/Src/lcd_advanced_demo.c ****         demo_ctx.balls[i].color = rainbow_colors[i % RAINBOW_SIZE];
ARM GAS  C:\Users\Dawn\AppData\Local\Temp\ccCmWBDU.s 			page 5


 116:../APP/LCD/Src/lcd_advanced_demo.c ****     }
 117:../APP/LCD/Src/lcd_advanced_demo.c **** }
