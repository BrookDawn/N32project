 659:../APP/Src/oled_test_demo.c ****     
 660:../APP/Src/oled_test_demo.c ****     /* 简单的正弦/余弦近似计算（使用查表法） */
 661:../APP/Src/oled_test_demo.c ****     /* 绘制旋转的线条（8条从中心辐射的线） */
 662:../APP/Src/oled_test_demo.c ****     for (int i = 0; i < 8; i++)
 663:../APP/Src/oled_test_demo.c ****     {
 664:../APP/Src/oled_test_demo.c ****         /* 使用简单的角度计算，避免使用sin/cos */
 665:../APP/Src/oled_test_demo.c ****         int16_t angle = (frame_count * 2 + i * 45) % 360;
 666:../APP/Src/oled_test_demo.c ****         
 667:../APP/Src/oled_test_demo.c ****         /* 简单的三角函数近似 */
 668:../APP/Src/oled_test_demo.c ****         if (angle < 90)
 669:../APP/Src/oled_test_demo.c ****         {
 670:../APP/Src/oled_test_demo.c ****             dx = angle;
 671:../APP/Src/oled_test_demo.c ****             dy = 90 - angle;
 672:../APP/Src/oled_test_demo.c ****         }
 673:../APP/Src/oled_test_demo.c ****         else if (angle < 180)
 674:../APP/Src/oled_test_demo.c ****         {
 675:../APP/Src/oled_test_demo.c ****             dx = 180 - angle;
 676:../APP/Src/oled_test_demo.c ****             dy = angle - 90;
 677:../APP/Src/oled_test_demo.c ****         }
 678:../APP/Src/oled_test_demo.c ****         else if (angle < 270)
 679:../APP/Src/oled_test_demo.c ****         {
 680:../APP/Src/oled_test_demo.c ****             dx = -(angle - 180);
 681:../APP/Src/oled_test_demo.c ****             dy = 270 - angle;
 682:../APP/Src/oled_test_demo.c ****         }
 683:../APP/Src/oled_test_demo.c ****         else
 684:../APP/Src/oled_test_demo.c ****         {
 685:../APP/Src/oled_test_demo.c ****             dx = -(360 - angle);
 686:../APP/Src/oled_test_demo.c ****             dy = -(angle - 270);
 687:../APP/Src/oled_test_demo.c ****         }
 688:../APP/Src/oled_test_demo.c ****         
 689:../APP/Src/oled_test_demo.c ****         /* 归一化并缩放 */
 690:../APP/Src/oled_test_demo.c ****         uint8_t x2 = 64 + (dx * 25) / 90;
 691:../APP/Src/oled_test_demo.c ****         uint8_t y2 = 32 + (dy * 25) / 90;
 692:../APP/Src/oled_test_demo.c ****         
 693:../APP/Src/oled_test_demo.c ****         /* 限制在屏幕范围内 */
