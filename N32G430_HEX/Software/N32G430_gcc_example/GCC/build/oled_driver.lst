 239:../APP/Src/oled_driver.c ****         holed->dirty_region.is_dirty = true;
 240:../APP/Src/oled_driver.c ****     }
 241:../APP/Src/oled_driver.c ****     else
 242:../APP/Src/oled_driver.c ****     {
