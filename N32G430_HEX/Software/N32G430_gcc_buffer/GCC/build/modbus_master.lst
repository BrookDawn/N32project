 325:../APP/Src/modbus_master.c **** /* 写多个寄存器实现 (功能码0x10) */
 326:../APP/Src/modbus_master.c **** static bool ModbusMaster_ExecuteWriteMultiple(uint16_t address, uint16_t count, const uint16_t* val
 327:../APP/Src/modbus_master.c **** {
 328:../APP/Src/modbus_master.c ****     if(values == NULL || count == 0U || count > MODBUS_MAX_WRITE_REGS)
 329:../APP/Src/modbus_master.c ****     {
