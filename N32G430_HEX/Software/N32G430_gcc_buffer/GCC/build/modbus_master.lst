 206:../APP/Src/modbus_master.c **** static bool ModbusMaster_ReadBytes(uint8_t* buffer, uint16_t length)
 207:../APP/Src/modbus_master.c **** {
 208:../APP/Src/modbus_master.c ****     if(buffer == NULL)
 209:../APP/Src/modbus_master.c ****     {
 210:../APP/Src/modbus_master.c ****         return false;
 211:../APP/Src/modbus_master.c ****     }
 212:../APP/Src/modbus_master.c **** 
 213:../APP/Src/modbus_master.c ****     uint32_t timeout = MODBUS_RESPONSE_TIMEOUT_MS;
 214:../APP/Src/modbus_master.c ****     uint16_t received = 0;
 215:../APP/Src/modbus_master.c **** 
 216:../APP/Src/modbus_master.c ****     while(received < length && timeout > 0)
 217:../APP/Src/modbus_master.c ****     {
 218:../APP/Src/modbus_master.c ****         uint16_t count = USART2_GetRxData(&buffer[received], length - received);
 219:../APP/Src/modbus_master.c ****         if(count > 0)
 220:../APP/Src/modbus_master.c ****         {
 221:../APP/Src/modbus_master.c ****             received += count;
 222:../APP/Src/modbus_master.c ****         }
 223:../APP/Src/modbus_master.c ****         else
 224:../APP/Src/modbus_master.c ****         {
 225:../APP/Src/modbus_master.c ****             SysTick_Delay_Ms(1);
 226:../APP/Src/modbus_master.c ****             timeout--;
 227:../APP/Src/modbus_master.c ****         }
 228:../APP/Src/modbus_master.c ****     }
 229:../APP/Src/modbus_master.c **** 
 230:../APP/Src/modbus_master.c ****     return (received == length);
 231:../APP/Src/modbus_master.c **** }
