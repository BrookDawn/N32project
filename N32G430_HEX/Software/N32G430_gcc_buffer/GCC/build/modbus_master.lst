 332:../APP/Src/modbus_master.c **** 
 333:../APP/Src/modbus_master.c ****     uint8_t txFrame[7 + MODBUS_MAX_WRITE_REGS * 2];
 334:../APP/Src/modbus_master.c ****     txFrame[0] = s_slaveAddress;
 335:../APP/Src/modbus_master.c ****     txFrame[1] = MODBUS_FUNC_WRITE_MULTIPLE_REGISTERS;
