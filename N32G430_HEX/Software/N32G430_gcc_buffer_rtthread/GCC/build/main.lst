  68:../core/src/main.c **** /**
  69:../core/src/main.c ****  * LED thread entry
  70:../core/src/main.c ****  * Blinks LEDs periodically
  71:../core/src/main.c ****  */
  72:../core/src/main.c **** static void led_thread_entry(void *parameter)
  73:../core/src/main.c **** {
  74:../core/src/main.c ****     (void)parameter;
  75:../core/src/main.c **** 
  76:../core/src/main.c ****     /* Initialize LEDs */
  77:../core/src/main.c ****     LED_Initialize(LED1_GPIO_PORT, LED1_GPIO_PIN, LED1_GPIO_CLK);
  78:../core/src/main.c ****     LED_Initialize(LED2_GPIO_PORT, LED2_GPIO_PIN | LED3_GPIO_PIN, LED2_GPIO_CLK);
  79:../core/src/main.c **** 
  80:../core/src/main.c ****     /* Turn off all LEDs */
  81:../core/src/main.c ****     LED_Off(LED2_GPIO_PORT, LED1_GPIO_PIN | LED2_GPIO_PIN | LED3_GPIO_PIN);
  82:../core/src/main.c **** 
  83:../core/src/main.c ****     rt_kprintf("LED thread started!\n");
  84:../core/src/main.c **** 
  85:../core/src/main.c ****     while (1)
  86:../core/src/main.c ****     {
  87:../core/src/main.c ****         /* Toggle LED1 */
  88:../core/src/main.c ****         LED_Toggle(LED1_GPIO_PORT, LED1_GPIO_PIN);
  89:../core/src/main.c ****         rt_thread_mdelay(500);
  90:../core/src/main.c **** 
  91:../core/src/main.c ****         /* Toggle LED2 */
  92:../core/src/main.c ****         LED_Toggle(LED2_GPIO_PORT, LED2_GPIO_PIN);
  93:../core/src/main.c ****         rt_thread_mdelay(500);
  94:../core/src/main.c **** 
  95:../core/src/main.c ****         /* Toggle LED3 */
  96:../core/src/main.c ****         LED_Toggle(LED3_GPIO_PORT, LED3_GPIO_PIN);
  97:../core/src/main.c ****         rt_thread_mdelay(500);
  98:../core/src/main.c ****     }
  99:../core/src/main.c **** }
